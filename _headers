# Cloudflare Pages headers (replaces netlify.toml [[headers]] rules)

# Baseline security headers. The render layer uses inline onclick handlers and one inline
# hash-shim script, so CSP ships as Report-Only first: it does NOT block anything, it only
# surfaces what an enforcing policy would break. Review reports, tighten (hash/nonce the
# inline script, drop 'unsafe-inline'), then promote to an enforcing Content-Security-Policy.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn.shopify.com; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Internal sales tool. Belt-and-braces with robots.txt; neither is access control.
# Both patterns are needed: /sales/* does NOT match the bare /sales/ index.
/sales/
  X-Robots-Tag: noindex, nofollow

/sales/*
  X-Robots-Tag: noindex, nofollow

# HTML is the cache entry point and must revalidate: it carries the ?v= content hashes that
# make everything below it safely immutable.
/
  Cache-Control: public, max-age=3600, must-revalidate

/index.html
  Cache-Control: public, max-age=3600, must-revalidate

/sales/
  Cache-Control: public, max-age=3600, must-revalidate

/sales/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# Pattern rules, NOT a per-file list. Every .js/.css is content-stamped by
# scripts/stamp-assets.mjs, so the URL changes whenever the bytes do and `immutable` is
# safe. The previous per-file enumeration was opt-in and had already silently missed
# tokens.css and the whole /sales/ bundle.
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/sales/*.js
  Cache-Control: public, max-age=31536000, immutable

/sales/*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
